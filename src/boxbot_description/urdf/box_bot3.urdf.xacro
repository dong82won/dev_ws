<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="box_bot">

    <xacro:property name="base_mass"   value="2.0"/> 
    <xacro:property name="base_size"   value="0.1"/>
    <xacro:property name="ground_clearance" value="0.01"/>

    <xacro:property name="wheel_mass"  value="0.2"/> 
    <xacro:property name="wheel_radius" value="0.035"/>
    <xacro:property name="wheel_length" value="0.01"/>
    <xacro:property name="wheel_ygap"   value="0.06"/> 

    <xacro:property name="caster_mass"   value="0.1"/> 
    <xacro:property name="caster_radius" value="0.01"/>
    <xacro:property name="caster_xgap"   value="0.035"/> 

    <xacro:include filename="box_bot3.gazebo.xacro" />
    <xacro:include filename="$(find realsense2_description)/urdf/_d435i.urdf.xacro"/>

    <material name="red"><color rgba="1.0 0.0 0.0 1"/></material>
    <material name="green_dark"><color rgba="0.0 0.5 0.0 1"/></material>
    <material name="black"><color rgba="0.0 0.0 0.0 1"/></material>
    <material name="orange"><color rgba="1.0 0.5 0.0 1.0"/></material>
    <material name="blue"><color rgba="0.088656 0.428691 0.491021 1"/></material>

    <link name="base_footprint"/>

    <link name="base_link">
        <visual>
            <geometry>
                <mesh filename="package://boxbot_description/meshes/cute_cube.dae" scale="0.1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.005" rpy="0 0 0"/> 
            <geometry>
                <box size="${base_size} ${base_size} 0.08"/> 
            </geometry>
        </collision>
        <inertial>
            <mass value="${base_mass}"/>
            <origin xyz="0.01 0 0" rpy="0 0 0"/> 
            <inertia ixx="0.00227" ixy="0" ixz="0" iyy="0.00227" iyz="0" izz="0.00333"/> </inertial>
    </link>


    <joint name="base_link_joint" type="fixed">
        <origin xyz="0 0 0.06" rpy="0 0 0"/> 
        <parent link="base_footprint" />
        <child link="base_link" />
    </joint>

    <xacro:sensor_d435i parent="base_link" name="camera" use_nominal_extrinsics="true">
        <origin xyz="0.053 0 0.05" rpy="0 0 0"/>
    </xacro:sensor_d435i>

    <xacro:macro name="wheel" params="prefix side color">
        <link name="${prefix}_wheel_link">
            <visual>
                <origin xyz="0 0 0" rpy="1.5707 0 0"/>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                <material name="orange"/>
            </visual>
            <collision>
                <origin xyz="0 0 0" rpy="1.5707 0 0"/>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
            </collision>
            <inertial>
                <origin xyz="0 0 0" rpy="1.5707 0 0"/>
                <mass value="${wheel_mass}"/>
                <inertia ixx="0.000063" ixy="0" ixz="0" iyy="0.0001225" iyz="0" izz="0.000063"/> 
            </inertial>
        </link>

        <joint name="${prefix}_wheel_joint" type="continuous">
            <origin xyz="0 ${side * wheel_ygap} -0.025" rpy="0 0 0" />
            <child link="${prefix}_wheel_link"/>
            <parent link="base_link"/>
            <axis xyz="0 1 0"/>
            <limit effort="10.0" velocity="10.0"/>
            <dynamics damping="1.0" friction="1.0"/> 
        </joint>

        <gazebo reference="${prefix}_wheel_link">
            <mu1>10.0</mu1>
            <mu2>10.0</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <minDepth>0.001</minDepth>
            <maxVel>0.1</maxVel>
            <fdir1>1 0 0</fdir1>
            <material>Gazebo/${color}</material>
        </gazebo>
    </xacro:macro>

    <xacro:wheel prefix="left"  side="1"  color="Green"/>
    <xacro:wheel prefix="right" side="-1" color="Orange"/>

    <xacro:macro name="caster" params="prefix x_pos">
        <link name="${prefix}_caster_link">
            <visual>
                <geometry><sphere radius="${caster_radius}"/></geometry>
                <material name="green_dark"/>
            </visual>
            <collision>
                <geometry><sphere radius="${caster_radius}"/></geometry>
            </collision>
            <inertial>
                <mass value="${caster_mass}"/>
                <inertia ixx="0.000004" ixy="0" ixz="0" iyy="0.000004" iyz="0" izz="0.000004"/> 
            </inertial>
        </link>

        <joint name="${prefix}_caster_joint" type="fixed">
            <parent link="base_link"/>
            <child link="${prefix}_caster_link"/>
            <origin xyz="${x_pos} 0 -0.05" rpy="0 0 0"/>
        </joint>

        <gazebo reference="${prefix}_caster_link">
            <mu1>0.0</mu1>
            <mu2>0.0</mu2>
            <slip1>1.0</slip1>
            <slip2>1.0</slip2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
            <minDepth>0.001</minDepth>
            <material>Gazebo/Purple</material>
        </gazebo>
    </xacro:macro>

    <xacro:caster prefix="front" x_pos="${caster_xgap}"/>
    <xacro:caster prefix="back"  x_pos="${-caster_xgap}"/>

    <link name="laser_scan_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry><mesh filename="package://boxbot_description/meshes/sensors/rplidar.dae" scale="1.0 1.0 1.0"/></geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.0204" rpy="0 0 0"/>
            <geometry><cylinder length="0.0408" radius="0.0375"/></geometry>
        </collision>
        <inertial>
            <mass value="0.01"/>
            <origin xyz="0 0 0.0204" rpy="0 0 0"/>
            <inertia ixx="6.06e-06" ixy="0" ixz="0" iyy="6.07e-06" iyz="0" izz="9.36e-06"/> 
        </inertial>
    </link>

    <joint name="laser_scan_link_joint" type="fixed">
        <origin rpy="0 0 0" xyz="0 0 0.05"/>
        <parent link="base_link"/>
        <child link="laser_scan_link"/>
    </joint>

    <link name="imu_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry><box size="0.015 0.015 0.0025"/></geometry>
            <material name="blue"/>
        </visual>
        <inertial>
            <mass value="0.001"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
        </inertial>
    </link>

    <joint name="imu_joint" type="fixed">
        <origin xyz="0.037 0.037 0.051" rpy="0 0 0"/>
        <parent link="base_link"/>
        <child link="imu_link"/>
    </joint>

    <gazebo reference="imu_link">
        <material>Gazebo/Red</material>
    </gazebo>

</robot>