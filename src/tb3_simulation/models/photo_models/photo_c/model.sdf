      <collision name="collision">
        <geometry>
          <!-- 가로 100cm 높이 49cm 두께 4.4cm -->
          <box><size>1.0 0.045 0.5</size></box>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh>
            <uri>model://photo_c/meshes/my_photo_frame3_visual.DAE</uri>
          </mesh>
        </geometry>
      <meta> <layer> 2 </layer></meta>
</visual>
    </link>
	<static>1</static>
  </model>
</sdf>
