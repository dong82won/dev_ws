<?xml version="1.0" ?>
<sdf version="1.6">
  <model name="photo_c">
    <link name="link">
      <inertial>
        <mass>1.5</mass>
      </inertial>
      <!-- <collision name="collision">
        <geometry>
          <mesh>
            <uri>model://photo_c/meshes/my_photo_frame3_collision.DAE</uri>
            <scale>1 1 1</scale>
          </mesh>
